{
  "model": {
    "compressionThreshold": 0.3
  },
  "contextManagement": {
    "historyWindow": {
      "maxTokens": 800000,
      "retainedTokens": 100000
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command|invoke_agent",
        "hooks": [
          {
            "name": "cognitive-guard-reminder",
            "type": "command",
            "command": "node .gemini/hooks/ast_reflection_reminder.cjs"
          }
        ]
      },
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "enforce-test-driven",
            "type": "command",
            "command": "node .gemini/hooks/enforce_tests.cjs"
          }
        ]
      }
    ]
  }
}
